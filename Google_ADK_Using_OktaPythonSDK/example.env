OKTA_DOMAIN=https://<your-okta-domain>.oktapreview.com
IDJAG_AUDIENCE=https://<your-okta-domain>.oktapreview.com/oauth2/<resource-authz-server-id>
RESOURCE_AUTHZ_SERVER=<resource-authz-server-id>
IDJAG_SCOPES=<custom-scope>
AT_AI_AGENT_ID=<okta-service-app-id>
AT_RESOURCE_URI=https://<your-resource-audience-uri>
GCP_PROJECT=<gcp-project-id>
GCP_LOCATION=us-central1
GCP_BUCKET=gs://<your-staging-bucket>
AUTH_ID_PREFIX=okta-authorization-native
CUSTOM_MCP_URL=https://<your-custom-mcp-server>/mcp
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp
GITHUB_RESOURCE_ORN=orn:oktapreview:idp:<org-id>:client-auth-settings:<resource-id>
AT_AGENT_PRIVATE_KEY_ID=<key-id-hex>
AT_AGENT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
<your-rsa-private-key-pem>
-----END PRIVATE KEY-----"
